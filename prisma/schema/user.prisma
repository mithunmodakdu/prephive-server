
model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  password           String
  role               EUserRole   @default(STUDENT)
  status             EUserStatus @default(ACTIVE)
  needPasswordChange Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  admin              Admin?
  teacher            Teacher?
  student            Student?

  @@map("users")
}

model Admin {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  profilePhoto  String?
  contactNumber String
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [email], references: [email])

  @@map("admins")
}

model Teacher {
  id                  String   @id @default(uuid())
  name                String
  email               String   @unique
  profilePhoto        String?
  contactNumber       String
  address             String?
  experience          Int      @default(0)
  gender              EGender
  teachingFee         Int
  qualification       String
  currentWorkingPlace String
  designation         String
  isDeleted           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [email], references: [email])

  @@map("teachers")
}

model Student {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  profilePhoto String?
  address      String?
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [email], references: [email])

  @@map("students")
}
